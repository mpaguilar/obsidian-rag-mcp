# Obsidian RAG Docker Compose Environment Variables
# Copy this file to .env and customize the values

# =============================================================================
# REQUIRED: MCP Server Security
# =============================================================================
# Change this to a secure random token for production
OBSIDIAN_RAG_MCP_TOKEN=your-secure-token-here

# =============================================================================
# REQUIRED: Embedding Provider API Key
# =============================================================================
# For OpenAI embeddings (default):
OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_API_KEY=sk-your-openai-key-here

# For OpenRouter embeddings:
# OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_PROVIDER=openrouter
# OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_API_KEY=sk-or-v1-your-openrouter-key
# OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_MODEL=openai/text-embedding-3-small

# For HuggingFace local embeddings (no API key needed):
# OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_PROVIDER=huggingface
# OBSIDIAN_RAG_ENDPOINTS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Optional: Chat Provider (for analysis features)
# =============================================================================
OBSIDIAN_RAG_ENDPOINTS_CHAT_API_KEY=sk-your-openai-key-here

# =============================================================================
# Optional: Vector Dimension
# =============================================================================
# Must match your embedding model's output dimension:
# - text-embedding-3-small: 1536 (default)
# - text-embedding-3-large: 3072
# - all-MiniLM-L6-v2: 384
# Note: pgvector HNSW index has a 2000 dimension limit
OBSIDIAN_RAG_DATABASE_VECTOR_DIMENSION=1536

# =============================================================================
# Optional: Vault Path Configuration
# =============================================================================
# Path on your host machine containing your Obsidian vault(s)
# Each subdirectory will be treated as a separate vault
VAULT_HOST_PATH=./vaults

# =============================================================================
# Optional: Logging Level
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
OBSIDIAN_RAG_LOGGING_LEVEL=INFO
